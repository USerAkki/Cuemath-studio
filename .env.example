# ─────────────────────────────────────────────────────────────────────────────
# CUEMATH SOCIAL STUDIO — Environment Variables
# Copy this file to .env.local (already gitignored).
# Set these in Vercel Dashboard → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── OPTION A: Groq  (RECOMMENDED — 30 RPM free tier, no rate limit issues) ──
# Get your FREE key at: https://console.groq.com  (no credit card needed)
# Click "API Keys" → "Create API Key"
GROQ_API_KEY=your groq_api_key_here

# Groq model — llama-3.3-70b-versatile is the best free option
GROQ_MODEL=llama-3.3-70b-versatile

# ── OPTION B: Gemini  (fallback — 15 RPM free tier) ─────────────────────────
# Get your FREE key at: https://aistudio.google.com/apikey
# NOTE: app auto-retries on rate limit, so Gemini also works fine for demos.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — gemini-1.5-flash has the best free tier limits
GEMINI_MODEL=gemini-1.5-flash

# ── You only need ONE of the two keys above. ─────────────────────────────────
# If BOTH are set, Groq is used first with Gemini as automatic fallback.

NODE_ENV=development
